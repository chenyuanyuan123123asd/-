rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Validation Helpers
    function isValidProperty(data) {
      return data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 1000;
    }

    function isValidTemplate(data) {
      return data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 500 &&
             data.content is string && data.content.size() <= 10000;
    }

    // Collections
    match /properties/{propertyId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || !('userId' in resource.data));
      allow create: if isSignedIn() && isValidProperty(request.resource.data);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || !('userId' in resource.data)) && isValidProperty(request.resource.data);
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || !('userId' in resource.data));
    }

    match /broadcastTemplates/{templateId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || !('userId' in resource.data));
      allow create: if isSignedIn() && isValidTemplate(request.resource.data);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || !('userId' in resource.data)) && isValidTemplate(request.resource.data);
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || !('userId' in resource.data));
    }
  }
}
